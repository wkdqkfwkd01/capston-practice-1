        "!pip install ultralytics streamlit pandas pillow\n",
        "\n",
        "import pandas as pd\n",
        "from ultralytics import YOLO\n",
        "\n",
        "# 1. 모델 및 DB 로드\n",
        "model = YOLO('yolov8n.pt') # 또는 직접 학습시킨 'best.pt'\n",
        "db = pd.read_csv('food_db.csv', index_col='name')\n",
        "\n",
        "def analyze_diet(image_path):\n",
        "    results = model.predict(image_path)\n",
        "    detected_names = [model.names[int(c)] for r in results for c in r.boxes.cls]\n",
        "\n",
        "    # 3. 영양소 합산\n",
        "    total = {\"cal\": 0, \"carbs\": 0, \"pro\": 0, \"fat\": 0, \"fiber\": 0, \"sodium\": 0}\n",
        "    details = []\n",
        "\n",
        "    for item in set(detected_names):\n",
        "        if item in db.index:\n",
        "            info = db.loc[item]\n",
        "            count = detected_names.count(item)\n",
        "            total[\"cal\"] += info['calories'] * count\n",
        "            total[\"carbs\"] += info['carbs'] * count\n",
        "            # ... 나머지 영양소도 동일하게 합산\n",
        "            details.append(f\"{info.name} ({count}개): {info['note']}\")\n",
        "\n",
        "    return total, details"
      ],
